# Copy to .env and adjust for your host.
# .env is gitignored; .env.example is the tracked template.

# Absolute path to the host's HuggingFace cache directory.
# Mounted into the Triton container so models are not re-downloaded on each restart.
HF_CACHE_DIR=/home/msamuels/.cache/huggingface

# Grafana admin password. Change before any non-local deployment.
GRAFANA_ADMIN_PASSWORD=admin
